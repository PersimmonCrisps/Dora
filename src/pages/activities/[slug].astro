---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
    const activities = await getCollection("activities");
    return activities.map((entry) => ({
        params: { slug: entry.slug },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const { title, date, description, image, gallery } = entry.data;
const mainImageUrl = image.startsWith("http")
    ? image
    : `/assets/images/activities/${image}`;
---

<Layout
    title={`${title} | 東京大学ドラえもんF同好会`}
    description={description}
    image={mainImageUrl}
>
    <main>
        <section
            class="hero"
            style="height: auto; padding-top: 180px; padding-bottom: 2rem;"
        >
            <div class="container hero-content">
                <h1 class="floating">{title}</h1>
                <p>{date}</p>
            </div>
        </section>

        <section class="activity-detail">
            <div class="container">
                <div class="card" style="background: var(--white);">
                    <!-- メイン画像 -->
                    <img
                        src={mainImageUrl}
                        alt={`${title}の写真`}
                        style="width: 100%; border-radius: 1rem; margin-bottom: 2rem;"
                    />

                    <!-- 本文 -->
                    <div class="activity-body">
                        <Content />
                    </div>
                </div>

                <!-- フォトギャラリー (SSGで描画) -->
                <div id="activity-gallery">
                    {
                        gallery && gallery.length > 0 && (
                            <>
                                <h2 style="color: var(--primary); font-size: 1.5rem; margin: 3rem 0 1.5rem; text-align: center;">
                                    フォトギャラリー
                                </h2>
                                <div class="gallery-grid">
                                    {gallery.map((img) => (
                                        <div class="gallery-item">
                                            <img
                                                src={`/assets/images/activities/${img}`}
                                                alt={`${title}の写真`}
                                            />
                                        </div>
                                    ))}
                                </div>
                            </>
                        )
                    }
                </div>

                <div style="margin-top: 3rem; text-align: center;">
                    <a href="/activities" class="btn">活動報告一覧に戻る</a>
                </div>
            </div>
        </section>
    </main>
</Layout>

<style is:global>
    .activity-body p {
        margin-bottom: 1.5rem;
    }
    .activity-body a {
        color: var(--primary);
        text-decoration: underline;
    }
</style>
