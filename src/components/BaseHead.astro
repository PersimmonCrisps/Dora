---
import { getImage } from 'astro:assets';
import defaultIcon from '../assets/images/icon.jpg';

interface Props {
	title: string;
	description: string;
	image?: string;
	noindex?: boolean;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image, noindex = false } = Astro.props;

// Process the default icon to get a hashed/optimized URL
const favicon = await getImage({ src: defaultIcon, width: 32, height: 32, format: 'jpg' });
const defaultOgImage = await getImage({ src: defaultIcon, width: 1200, height: 630, format: 'jpg' });
const resolvedImage = image || defaultOgImage.src;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/jpeg" href={favicon.src} />
<meta name="generator" content={Astro.generator} />

{noindex && <meta name="robots" content="noindex, nofollow, noarchive" />}

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(resolvedImage, Astro.site)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(resolvedImage, Astro.site)} />


<!-- Fonts are now self-hosted in global.css -->
