---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BaseHead from '../components/BaseHead.astro';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	image?: string;
	noindex?: boolean;
}

const { 
	title, 
	description = "東京大学ドラえもんF同好会の公式サイト。ドラえもんや藤子・F・不二雄作品が好きな学生が集まるインカレサークルです。",
	image = "/assets/images/icon.jpg",
	noindex = false
} = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
	<head>
		<BaseHead title={title} description={description} image={image} noindex={noindex} />

		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-61HH88G3J8" is:inline></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag() { dataLayer.push(arguments); }
			gtag('js', new Date());
			gtag('config', 'G-61HH88G3J8');
		</script>
	</head>
	<body>
		<Header />
		<slot />
		<Footer />
		<script src="/assets/js/main.js" is:inline></script>
	</body>
</html>

<style is:global>
	/* Any additional global styles or overrides */
</style>
